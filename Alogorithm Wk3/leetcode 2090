#include <vector>

using namespace std;

class Solution {
public:
    vector<int> getAverages(vector<int>& nums, int k) {
        int n = nums.size();
        int windowSize = 2 * k + 1;
        vector<int> ans(n, -1);  
        if (n < windowSize) {
            return ans;
        }

        long long windowSum = 0; 
         
        for (int i = 0; i < windowSize; i++) {
            windowSum += nums[i];
        }

        
        ans[k] = windowSum / windowSize;
 
        for (int i = k + 1; i < n - k; i++) {
            
            windowSum += nums[i + k];
            windowSum -= nums[i - k - 1];
            
            ans[i] = windowSum / windowSize;
        }

        return ans;
    }
};
